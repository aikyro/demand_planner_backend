# =============================================================================
# Version Control
# =============================================================================
.git
.gitignore
.gitattributes

# =============================================================================
# Virtual Environments
# =============================================================================
.venv/
venv/
env/
ENV/
__pycache__/

# =============================================================================
# Python Cache & Build Artifacts
# =============================================================================
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Testing & Coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
tests/
test/
*_test.py
*_tests.py

# =============================================================================
# IDE & Editors
# =============================================================================
.vscode/
.idea/
.vs/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# =============================================================================
# Documentation & Markdown (keep README.md)
# =============================================================================
*.md
!README.md

# =============================================================================
# Docker Files (don't copy into image)
# =============================================================================
Dockerfile*
docker-compose*
.dockerignore

# =============================================================================
# Logs & Temporary Files
# =============================================================================
*.log
logs/
*.tmp
*.temp
.cache/

# =============================================================================
# Development Scripts (not needed in production container)
# =============================================================================
*.postman_collection.json
